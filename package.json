{
  "name": "@tetrac/login-sdk",
  "version": "0.4.0",
  "description": "Reusable, non-custodial authentication SDK: email/passkey, Web3 wallet, and biometric (WebAuthn PRF) login with client-side wallet generation. Redis / Upstash / Vercel KV storage.",
  "license": "MIT",
  "homepage": "https://github.com/tetrac-official/tetrac-login-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetrac-official/tetrac-login-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/tetrac-official/tetrac-login-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "smoke:biometric": "npm run build && node scripts/smoke-biometric.mjs",
    "smoke:multiapp": "npm run build && node scripts/smoke-multi-app.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.98.0",
    "@upstash/redis": "^1.34.0",
    "@vercel/kv": "^3.0.0",
    "ioredis": "^5.6.0",
    "next": ">=14",
    "react": ">=18",
    "tweetnacl": "^1.0.3",
    "viem": "^2.46.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    },
    "@vercel/kv": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@upstash/redis": "^1.34.0",
    "@vercel/kv": "^3.0.0",
    "ioredis": "^5.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-jest": "^29.2.0",
    "tsup": "^8.3.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^6.0.3",
    "viem": "^2.46.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "authentication",
    "web3",
    "passkey",
    "webauthn",
    "solana",
    "evm",
    "wallet",
    "non-custodial",
    "sdk"
  ]
}
